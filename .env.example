# =============================================================================
# OrchestraAI Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Credential tiers:
#   Tier 1: Required before build (get these first, ~10 min)
#   Tier 2: Required for live platform testing (after build)
#   Tier 3: Required after LLC registration (weeks later)
#   Tier 4: Auto-generated by Docker (zero user action)
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=OrchestraAI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
STEALTH_MODE=true

# -----------------------------------------------------------------------------
# TIER 1 -- LLM PROVIDERS (Get these first, ~$5 each, ~10 min total)
# -----------------------------------------------------------------------------

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama (local, auto-handled by Docker -- no key needed)
OLLAMA_BASE_URL=http://ollama:11434

# Model routing defaults
DEFAULT_FAST_MODEL=gpt-4o-mini
DEFAULT_CAPABLE_MODEL=claude-sonnet-4-20250514
DEFAULT_LOCAL_MODEL=llama3.2

# -----------------------------------------------------------------------------
# TIER 2 -- PLATFORM API KEYS (After build, for live testing)
# -----------------------------------------------------------------------------

# X / Twitter ($100/mo Basic plan -- https://developer.x.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Google / YouTube (free -- https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_API_KEY=

# Pinterest (free -- https://developers.pinterest.com)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# TikTok (free -- https://developers.tiktok.com)
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# -----------------------------------------------------------------------------
# TIER 3 -- REQUIRES LLC / BUSINESS VERIFICATION (Weeks later)
# -----------------------------------------------------------------------------

# Meta / Facebook + Instagram (free -- https://developers.facebook.com)
META_APP_ID=
META_APP_SECRET=

# LinkedIn (free -- https://www.linkedin.com/developers)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Snapchat (free -- https://business.snapchat.com)
SNAPCHAT_APP_ID=
SNAPCHAT_APP_SECRET=

# Google Ads (free -- https://developers.google.com/google-ads)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# TIER 4 -- INFRASTRUCTURE (Auto-handled by Docker, zero user action)
# -----------------------------------------------------------------------------

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://orchestra:orchestra_dev_password@postgres:5432/orchestraai

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Security (auto-generated on first run)
JWT_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
FERNET_KEY=CHANGE-ME-generate-with-python-cryptography-fernet

# Encryption
ENCRYPTION_KEY=CHANGE-ME-generate-aes-256-key

# Video generation -- fal.ai (https://fal.ai/dashboard/keys)
FAL_API_KEY=

# SMTP -- Email notifications (optional, alerts are logged if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@useorchestra.dev

# Stripe billing (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_STARTER_PRICE_ID=price_starter_plan_id
STRIPE_AGENCY_PRICE_ID=price_agency_plan_id
FRONTEND_URL=http://localhost:3000
